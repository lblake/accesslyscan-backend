# ─── Required ────────────────────────────────────────────────────────────────

# WAVE API key — https://wave.webaim.org/api/
WAVE_API_KEY=

# Anthropic Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Absolute base URL of this API (no trailing slash)
# Used to construct pdfUrl in POST /api/audit responses
# Example: https://accesslyscan-api.onrender.com
BASE_URL=http://localhost:3000

# Node environment — controls SQLite path and logging behaviour
# Values: "development" | "production"
NODE_ENV=development

# Port — Render sets this automatically; leave blank locally to default to 3000
PORT=

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (no spaces between entries)
# Wildcards not supported here — *.lovable.app and localhost:* handled in code
CORS_ORIGIN=https://accesslyscan.ai,http://localhost:3000,http://localhost:5173

# ─── GoHighLevel webhook ─────────────────────────────────────────────────────

# Webhook URL from GHL automation (Inbound Webhook trigger)
# When set, fires after each successful scan to trigger the email sequence
GHL_WEBHOOK_URL=
